{
	"name": "@natoboram/ai-slop",
	"version": "0.0.0",
	"description": "A collection of vibe-coded scripts.",
	"keywords": [],
	"homepage": "https://github.com/NatoBoram/ai-slop",
	"bugs": {
		"url": "https://github.com/NatoBoram/ai-slop/issues"
	},
	"license": "AGPL-3.0-or-later",
	"author": {
		"name": "Nato Boram",
		"url": "https://github.com/NatoBoram"
	},
	"funding": [
		{
			"type": "patreon",
			"url": "https://www.patreon.com/NatoBoram"
		},
		{
			"type": "individual",
			"url": "https://paypal.me/NatoBoram/5"
		}
	],
	"files": [
		"dist",
		"!dist/**/*.test.*"
	],
	"type": "module",
	"repository": "github:NatoBoram/ai-slop",
	"scripts": {
		"build": "tsgo",
		"build:watch": "tsgo --watch",
		"clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo",
		"dev:myanimelist": "node src/myanimelist.ts",
		"format": "prettier --write .",
		"lint": "eslint . && markdownlint-cli2 \"**/*.md\" && prettier --check .",
		"lint:fix": "eslint --fix --quiet .; markdownlint-cli2 \"**/*.md\" --fix; prettier --list-different --write .",
		"start:myanimelist": "node dist/myanimelist.js"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.6.0",
		"@typescript/native-preview": "7.0.0-dev.20260501.1",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"markdownlint-cli2": "^0.22.1",
		"prettier": "^3.8.3",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.59.1"
	},
	"engines": {
		"node": ">=24"
	},
	"private": true
}
