{
	"name": "@natoboram/ai-slop",
	"version": "0.0.0",
	"description": " A collection of vibe-coded scripts.",
	"keywords": [],
	"homepage": "https://github.com/NatoBoram/ai-slop",
	"bugs": {
		"url": "https://github.com/NatoBoram/ai-slop/issues"
	},
	"license": "AGPL-3.0-or-later",
	"author": {
		"name": "Nato Boram",
		"url": "https://github.com/NatoBoram"
	},
	"funding": [
		{
			"type": "patreon",
			"url": "https://www.patreon.com/NatoBoram"
		},
		{
			"type": "individual",
			"url": "https://paypal.me/NatoBoram/5"
		}
	],
	"files": [
		"dist",
		"!dist/**/*.test.*"
	],
	"repository": "github:NatoBoram/ai-slop",
	"scripts": {
		"build": "tsgo",
		"build:watch": "tsgo --watch",
		"clean": "rm -rf coverage dist docs node_modules tsconfig.tsbuildinfo",
		"docs": "typedoc",
		"format": "prettier --write .",
		"lint": "eslint . && markdownlint-cli2 \"**/*.md\" && prettier --check .",
		"lint:fix": "eslint --fix --quiet .; markdownlint-cli2 \"**/*.md\" --fix; prettier --list-different --write .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.2",
		"@typescript/native-preview": "7.0.0-dev.20260404.1",
		"@vitest/coverage-v8": "4.1.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"markdownlint-cli2": "^0.22.0",
		"prettier": "^3.8.1",
		"typedoc": "^0.28.18",
		"typescript": "6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"type": "module",
	"private": true
}
